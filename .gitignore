# Ignore private/runtime files so this public Pi config repo stays share-safe.
# This repo should contain only curated settings, themes, extensions, and docs.

# Secrets / credentials
/auth.json

# Conversation history / personal session data
/sessions/

# Pi-managed binaries / caches
/bin/
/cache/
/tmp/

# OS/editor junk
.DS_Store
*.swp
*.swo

# Dependencies, if extension packages are added later
node_modules/
